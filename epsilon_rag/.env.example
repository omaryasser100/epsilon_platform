# Copy to .env (which is gitignored) and fill in.
#
#     cp .env.example .env
#
# Both docker-compose.yml and pydantic-settings (core/config.py) read
# from .env automatically — no separate "load this" command needed.


# ── PostgreSQL (read by docker-compose.yml AND by core/config.py) ──────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_db
POSTGRES_PORT=5432

# Bind address for the published port. 127.0.0.1 (default) keeps the
# DB reachable only from this machine. Set to 0.0.0.0 to expose on the
# LAN, or to a specific interface IP for selective exposure.
POSTGRES_BIND=127.0.0.1

# Container name. The bootstrap docs reference `rag-pgvec`.
POSTGRES_CONTAINER_NAME=rag-pgvec

# Connection string used by the Python CLIs (main.py / query.py /
# channels.py). Matches POSTGRES_* above by default; override if you
# point at a remote DB.
#
# Host CLIs use localhost (published port). Compose services (migrate,
# app) override this to postgres:5432 via docker-compose.yml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db


# ── MinIO (object storage for raw PDFs, extracted markdown, metadata) ─────
# Root creds — used by the MinIO server container itself. With default
# MinIO config these double as the API access/secret keys (see below).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Client-side (Python `minio` SDK) config consumed by core/config.py.
# ENDPOINT is host:port without scheme; flip USE_SSL=true for HTTPS.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# Bucket + key layout. Objects land at:
#     <BUCKET>/<BUCKET_PREFIX>/<channel_id>/{raw,markdown,metadata}/...
MINIO_BUCKET=epsilon-rag
MINIO_BUCKET_PREFIX=channels

# Container name for `docker ps` / network alias.
MINIO_CONTAINER_NAME=rag-minio

# Host directory bind-mounted as /data in the `app` compose service.
# PDF_HOST_DIR=./data


# ── Models ────────────────────────────────────────────────────────────────
# Force CPU when CUDA isn't available; defaults to "cuda" otherwise.
# DEVICE=cpu

# fp16 halves VRAM and roughly doubles throughput on GPU. Set to false
# on CPU (fp16 is slower there).
# FP16=true
